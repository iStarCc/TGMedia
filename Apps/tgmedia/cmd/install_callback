#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/tgmedia.log"
VENV_DIR="${TRIM_PKGVAR}/venv"

export PATH=/var/apps/python312/target/bin:$PATH

echo "$(date '+%Y-%m-%d %H:%M:%S') - Install callback started" >> "${LOG_FILE}"

switch_to_flag() {
    [ "$1" = "true" ] && echo "1" || echo "0"
}

DATA_SHARE="${TRIM_DATA_SHARE_PATHS%%:*}"
DOWNLOAD_PATH="$(echo "${wizard_download_path:-}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
if [ -z "${DOWNLOAD_PATH}" ]; then
    DOWNLOAD_PATH="${DATA_SHARE}"
fi

if ! mkdir -p "${DOWNLOAD_PATH}" 2>> "${LOG_FILE}"; then
    echo "无法创建下载目录: ${DOWNLOAD_PATH}" > "${TRIM_TEMP_LOGFILE}"
    exit 1
fi

mkdir -p "${TRIM_PKGETC}"
cat > "${TRIM_PKGETC}/app.conf" <<EOF
max_concurrent=${wizard_max_concurrent:-3}
auto_download=0
download_path=${DOWNLOAD_PATH}
download_by_channel=$(switch_to_flag "${wizard_download_by_channel:-false}")
download_by_media_type=$(switch_to_flag "${wizard_download_by_media_type:-false}")
allowed_extensions=[]
sync_limit=100
sync_days=0
EOF

echo "$(date '+%Y-%m-%d %H:%M:%S') - Config saved (download_path=${DOWNLOAD_PATH})" >> "${LOG_FILE}"

python3 -m venv "${VENV_DIR}" >> "${LOG_FILE}" 2>&1
if [ $? -ne 0 ]; then
    echo "Python 虚拟环境创建失败" > "${TRIM_TEMP_LOGFILE}"
    exit 1
fi

source "${VENV_DIR}/bin/activate"
pip install -r "${TRIM_APPDEST}/server/requirements.txt" --quiet >> "${LOG_FILE}" 2>&1
if [ $? -ne 0 ]; then
    echo "Python 依赖安装失败，请检查网络连接" > "${TRIM_TEMP_LOGFILE}"
    deactivate
    exit 1
fi
deactivate

echo "$(date '+%Y-%m-%d %H:%M:%S') - Install callback completed" >> "${LOG_FILE}"
exit 0
